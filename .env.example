# Runtime
NODE_ENV=production
PORT=3000

# Public site metadata
NEXT_PUBLIC_SITE_URL=https://elevareai.online
NEXT_PUBLIC_SITE_NAME=AusCham Cambodia
NEXT_PUBLIC_DEFAULT_LOCALE=en

# APIs / integrations
NEXT_PUBLIC_API_BASE_URL=https://elevareai.online/api
CMS_PROVIDER=contentful
CMS_SPACE_ID=replace_me
CMS_ENVIRONMENT=master
CMS_ACCESS_TOKEN=replace_me
CMS_PREVIEW_ACCESS_TOKEN=replace_me

# Email / contact pipeline
CONTACT_INBOX=team@elevareai.online
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace_me
SMTP_PASS=replace_me
SMTP_FROM=noreply@elevareai.online

# Observability
SENTRY_DSN=
LOG_LEVEL=info

# Security
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Forms
FORM_NOTIFICATION_TO=team@elevareai.online
FORM_CAPTCHA_ENABLED=
FORM_CAPTCHA_PROVIDER=recaptcha
FORM_CAPTCHA_SECRET=
